# ============================================================
# OMARI Bot — Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- Telegram ---
# Obtain from @BotFather on Telegram
TELEGRAM_TOKEN=

# Comma-separated list of authorized Telegram user IDs (integers as strings)
# Find your ID by messaging @userinfobot
ALLOWED_USER_IDS=114324923,987654321

# --- Dropbox OAuth2 (Refresh Token Flow) ---
# Do NOT use a short-lived access token here.
# Generate via: https://www.dropbox.com/developers/apps
# Use the offline access type to receive a refresh token.
DROPBOX_REFRESH_TOKEN=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# --- RSS Feeds ---
# Comma-separated list of RSS/Atom feed URLs to monitor
RSS_URLS=

# How often to poll feeds, in seconds (default: 900 = 15 minutes)
RSS_POLL_INTERVAL=900

# --- Download Settings ---
# Maximum number of simultaneous torrent downloads (default: 2)
MAX_CONCURRENT_DOWNLOADS=2

# Local directory for in-progress downloads (default: ./downloads)
DOWNLOAD_PATH=./downloads

# Minutes without progress before a download is considered stalled (default: 30)
DOWNLOAD_TIMEOUT_MINUTES=30


# Dropbox destination directories (media-type routing)
SHOWS_DIRECTORY=Shows/Current/
MOVIES_DIRECTORY=Movies/Current

# --- Notifications ---
# Telegram user ID to notify when RSS-sourced downloads complete.
# Find your ID by messaging @userinfobot. Leave unset (or 0) to disable.
NOTIFICATION_CHAT_ID=0